<svg xmlns="http://www.w3.org/2000/svg" width="400" height="300" viewBox="0 0 400 300">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6aaa64;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4a8a44;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="300" fill="#f5f5f5"/>
  
  <!-- Quote marks -->
  <text x="50" y="80" font-family="Georgia, serif" font-size="80" fill="url(#grad1)" opacity="0.3">"</text>
  <text x="320" y="220" font-family="Georgia, serif" font-size="80" fill="url(#grad1)" opacity="0.3">"</text>
  
  <!-- Title -->
  <text x="200" y="140" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#1a1a1a" text-anchor="middle">Quote</text>
  <text x="200" y="175" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="#6aaa64" text-anchor="middle">Guessing Game</text>
  
  <!-- Decorative elements -->
  <circle cx="80" cy="250" r="15" fill="#6aaa64" opacity="0.5"/>
  <circle cx="320" cy="50" r="15" fill="#6aaa64" opacity="0.5"/>
</svg>